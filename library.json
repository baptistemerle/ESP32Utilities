{
  "name": "ESP32Utilities",
  "version": "0.0.1",
  "description": "Various utilites for ESP32",
  "keywords": ["utilities", "patterns"],
  "authors": [
    {
      "name": "Baptiste Merle"
    }
  ],
  "frameworks": "arduino",
  "platforms": "espressif32",
  "dependencies": {
    "lovyan03/LovyanGFX": "^1.1.12",
    "lewisxhe/SensorLib": "^0.2.0",
    "lvgl/lvgl": "^8.3.9"
  },
  "build": {
    "flags": [
      "-Wall",
      "-Wextra",
      "-Wshadow",
      "-Werror=return-type",
      "-Wdouble-promotion"
    ]
  }
}